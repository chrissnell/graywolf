post_install() {
  systemctl daemon-reload
  echo "Graywolf installed. Enable and start with:"
  echo "  systemctl enable --now graywolf.service"
  echo ""
  echo "Web UI: http://localhost:8080"
}

post_upgrade() {
  systemctl daemon-reload
  if systemctl is-active --quiet graywolf.service; then
    systemctl restart graywolf.service
  fi
}

pre_remove() {
  systemctl stop graywolf.service 2>/dev/null || true
  systemctl disable graywolf.service 2>/dev/null || true
}
