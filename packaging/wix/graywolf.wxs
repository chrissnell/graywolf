<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Graywolf"
           Manufacturer="chrissnell"
           Version="$(var.Version)"
           UpgradeCode="c3a7f1d9-5e2b-4c8a-9f0d-b6e4a8c2d0f3"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Graywolf is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="Graywolf" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ModemComponents" />
    </Feature>
  </Package>

  <!-- Install directory -->
  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Graywolf" />
    </StandardDirectory>
  </Fragment>

  <!-- Main binary + Windows service -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="d4f6e8a0-1b2c-3d4e-5f6a-7b8c9d0e1f2a">
        <File Id="graywolf.exe" Source="$(var.BinaryPath)" KeyPath="yes" />
        <ServiceInstall Id="GraywolfService"
                        Name="graywolf"
                        DisplayName="Graywolf APRS"
                        Description="APRS radio transceiver and gateway"
                        Start="auto"
                        Type="ownProcess"
                        ErrorControl="normal"
                        Arguments="-config &quot;[INSTALLFOLDER]graywolf.db&quot; -modem &quot;[INSTALLFOLDER]graywolf-modem.exe&quot; -http 0.0.0.0:8080" />
        <ServiceControl Id="GraywolfServiceControl"
                        Name="graywolf"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Modem binary -->
  <Fragment>
    <ComponentGroup Id="ModemComponents" Directory="INSTALLFOLDER">
      <Component Id="ModemExecutable" Guid="e5a7b9c1-2d3e-4f5a-6b7c-8d9e0f1a2b3c">
        <File Id="graywolf_modem.exe" Source="$(var.ModemPath)" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
